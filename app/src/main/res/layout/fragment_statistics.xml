<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:isScrollContainer="true">

    <!-- LineChart для динамики расходов -->
    <com.github.mikephil.charting.charts.LineChart
        android:id="@+id/lineChart"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="32dp"
        android:background="#D0FFFFFF"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- StatsView для диаграммы соотношения -->
    <ru.github.debitcredit.customview.StatsView
        android:id="@+id/statsView"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/lineChart" />

    <!-- Круглые кнопки периодов -->
    <LinearLayout
        android:id="@+id/periodButtonsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        app:layout_constraintTop_toBottomOf="@+id/statsView">

        <Button
            android:id="@+id/dayButton"
            style="@style/RoundButtonGold"
            android:text="@string/day" />

        <Button
            android:id="@+id/weekButton"
            style="@style/RoundButtonGold"
            android:text="@string/week" />

        <Button
            android:id="@+id/monthButton"
            style="@style/RoundButtonGold"
            android:text="@string/month" />

        <Button
            android:id="@+id/yearButton"
            style="@style/RoundButtonGold"
            android:text="@string/year" />

    </LinearLayout>

    <!-- RecyclerView для 4 объектов информации -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/itemsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@+id/periodButtonsContainer"
        app:layout_constraintBottom_toTopOf="@+id/backButton"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- Кнопка назад -->
    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/ic_left"
        android:background="@drawable/circle_background"
        android:scaleType="centerInside"
        android:padding="12dp"
        app:tint="?android:attr/textColorPrimary"
        android:contentDescription="@string/cancel"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>