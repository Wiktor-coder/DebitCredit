<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- LineChart для динамики доходов/расходов -->
    <com.github.mikephil.charting.charts.LineChart
        android:id="@+id/lineChart"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="32dp"
        android:background="#D0FFFFFF"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- StatsView для диаграммы соотношения -->
    <ru.github.debitcredit.customview.StatsView
        android:id="@+id/statsView"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginTop="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/lineChart" />

    <!-- Круглые кнопки периодов (между графиком и StatsView) -->
    <LinearLayout
        android:id="@+id/periodButtonsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@+id/statsView">

        <Button
            android:id="@+id/dayButton"
            style="@style/RoundButtonGold"
            android:text="День" />
        <Button
            android:id="@+id/weekButton"
            style="@style/RoundButtonGold"
            android:text="Неделя" />
        <Button
            android:id="@+id/monthButton"
            style="@style/RoundButtonGold"
            android:text="Месяц" />
        <Button
            android:id="@+id/quarterButton"
            style="@style/RoundButtonGold"
            android:text="Квартал" />
        <Button
            android:id="@+id/yearButton"
            style="@style/RoundButtonGold"
            android:text="Год" />

    </LinearLayout>

    <!-- Текст с процентами и суммами -->
    <TextView
        android:id="@+id/percentageTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="📊 Потрачено: 0% от дохода"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/periodButtonsContainer" />

    <!-- Круглая кнопка назад -->
    <Button
        android:id="@+id/backButton"
        style="@style/RoundButtonGold"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginBottom="32dp"
        android:text="←"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>